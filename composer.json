{
  "name": "imrev-agency/exchange1c",
  "type": "library",
  "description": "Catalog Loader from 1c - CommerceML protocol",
  "keywords": [
    "1c",
    "CommerceML",
    "1c-exchange",
    "1c-php"
  ],
  "homepage": "https://github.com/imrev-agency/exchange1c",
  "license": "MIT",
  "authors": [
    {
      "name": "Anton Kartsev",
      "role": "Developer"
    },
    {
      "name": "Aleksey Balobanov",
      "email": "jalex21@mail.ru"
    }
  ],
  "minimum-stability": "stable",
  "autoload": {
    "psr-4": {
      "Bigperson\\Exchange1C\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require": {
    "php": ">=8.0",
    "ext-zip": "*",
    "ext-simplexml": "*",
    "imrev-agency/commerceml": "^1.1.0",
    "illuminate/contracts": "^10|^11|^12|^13"
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/imrev-agency/php-commerceml.git"
    }
  ],
  "extra": {
    "laravel": {
      "providers": [
        "Bigperson\\Exchange1C\\Laravel\\Exchange1CServiceProvider"
      ]
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5 || ^10.0",
    "illuminate/session": "^12|^13",
    "symfony/http-foundation": "^7.2",
    "symfony/event-dispatcher": "^7.2"
  }
}
